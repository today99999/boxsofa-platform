NEXT_PUBLIC_SITE_URL=https://boxsofa.eu
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local prototype login is for development only. Keep false/empty in production.
NEXT_PUBLIC_ENABLE_LOCAL_AUTH=

# Email provider is checked before launch. The built-in sender currently supports:
# EMAIL_PROVIDER=resend
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=

# Stripe is reserved for the next phase after the European bank account is ready.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
