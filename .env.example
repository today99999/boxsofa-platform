NEXT_PUBLIC_SITE_URL=https://boxsofa.eu
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics attribution signing. In production this can be omitted only when
# SUPABASE_SERVICE_ROLE_KEY is configured; it is then derived with a separate purpose.
ANALYTICS_TOKEN_SECRET=

# Local prototype login is for development only. Keep false/empty in production.
NEXT_PUBLIC_ENABLE_LOCAL_AUTH=

# Email provider is checked before launch. The built-in sender currently supports:
# EMAIL_PROVIDER=resend
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=

# Stripe Checkout. Use test keys first; add the webhook secret only after the webhook endpoint is configured.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
