{
  "name": "boxsofa-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test lib/*.test.ts lib/data-center/*.test.ts lib/server/*.test.ts",
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit --pretty false",
    "prelaunch": "npm run build && npm run typecheck",
    "start": "next start",
    "lint": "next lint",
    "smoke": "node scripts/prelaunch-smoke.mjs",
    "seo:audit": "node scripts/seo-audit.mjs",
    "api:auth-audit": "node scripts/api-auth-audit.mjs",
    "analytics:intents:integration": "node scripts/analytics-consent-intents-integration.mjs",
    "stripe:financial:integration": "node scripts/stripe-financial-integration.mjs",
    "after-sales:integration": "node scripts/after-sales-integration.mjs",
    "db:migrations:verify": "node scripts/verify-migration-manifest.mjs",
    "db:migrations:verify-remote": "node scripts/verify-migration-manifest.mjs --remote",
    "db:bootstrap:validate": "node scripts/validate-bootstrap-sql.mjs",
    "db:bootstrap:execute": "node scripts/execute-bootstrap-pglite.mjs",
    "env:check": "node scripts/check-env.mjs",
    "env:check:release": "node scripts/check-env.mjs --release",
    "prelaunch:local": "npm run env:check && npm run prelaunch && npm run smoke && npm run seo:audit && npm run api:auth-audit",
    "production:ready": "node scripts/production-readiness.mjs",
    "production:ready:release-config": "node scripts/production-readiness.mjs --release --environment-only",
    "production:verify:local": "node scripts/production-verify-local.mjs",
    "production:verify": "node scripts/production-verify.mjs --release",
    "deploy:preflight": "node scripts/deploy-preflight.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.45.4",
    "lucide-react": "^1.26.0",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "typescript": "^5.7.2"
  }
}
